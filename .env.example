# ==================== 基础配置 ====================
JWT_SECRET=your-secret-key-change-in-production
DB_PATH=./management.db
PORT=8080

# ==================== 企业微信自建应用配置 ====================
# 企业ID，在「我的企业」页面最下方
WECOM_CORP_ID=

# 自建应用的 AgentId（纯数字）
WECOM_AGENT_ID=0

# 自建应用的 Secret
WECOM_SECRET=

# 通知模式: wecom(企业微信) | log(仅打印日志，默认)
NOTIFY_MODE=log

# 是否异步发送通知: true | false
NOTIFY_ASYNC=true
